{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=App_Data/adoztech.db"
  },
  "SiteSettings": {
    "SiteName": "Adoztech",
    "BaseUrl": "https://www.adoztech.com",
    "DefaultImagePath": "/img/og-default.svg",
    "DefaultLocale": "tr_TR",
    "AlternateLocale": "en_US",
    "ContactEmail": "info@adoztech.com",
    "ContactPhone": "+90 555 000 00 00",
    "WhatsappPhone": "+905550000000",
    "AddressTr": "Istanbul, Turkiye",
    "AddressEn": "Istanbul, Turkiye",
    "LinkedinUrl": "https://www.linkedin.com/company/adoztech",
    "InstagramUrl": "https://www.instagram.com/adoztech"
  },
  "SmtpSettings": {
    "Host": "mail.adoztech.com",
    "Port": 587,
    "UseSsl": true,
    "UserName": "info@adoztech.com",
    "Password": "CHANGE_ME",
    "FromEmail": "info@adoztech.com",
    "FromName": "Adoztech Website",
    "ToEmail": "info@adoztech.com",
    "TimeoutSeconds": 20
  },
  "BrandingSettings": {
    "BrandName": "Adoztech",
    "TaglineTr": "Dijital urunleri strateji, tasarim ve yazilimla olgunlastiriyoruz.",
    "TaglineEn": "We shape digital products through strategy, design, and software craftsmanship.",
    "LogoText": "Adoztech"
  },
  "LocalizationSettings": {
    "DefaultCulture": "tr",
    "SupportedCultures": [ "tr", "en" ]
  },
  "AllowedHosts": "*",
  "Serilog": {
    "Using": [ "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "shared": true,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  }
}
