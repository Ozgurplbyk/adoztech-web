@using Adoztech.Web.Resources
@using Adoztech.Web.Services.Routing
@inject IStringLocalizer<SharedResource> Localizer
@inject ICultureRouteService RouteService
@model HomePageViewModel
@{
    ViewData["Seo"] = Model.Seo;
    var panelItems = Model.Culture == "en"
        ? new[]
        {
            ".NET-based corporate infrastructure",
            "Bilingual, SEO-aware page structure",
            "Delivery logic aligned across strategy, design, and operations"
        }
        : new[]
        {
            ".NET tabanli kurumsal altyapi",
            "Iki dilli, SEO duyarliligi yuksek sayfa yapisi",
            "Strateji, tasarim ve operasyon uyumlu teslim mantigi"
        };
}
<section class="hero-section">
    <div class="container hero-grid">
        <div class="hero-copy">
            <span class="eyebrow">@Model.Content.Eyebrow</span>
            <h1>@Model.Content.Title</h1>
            <p class="lead">@Model.Content.Lead</p>
            <div class="hero-actions">
                <a class="button button--primary" href="@RouteService.GetPath(Model.Culture, "quote")">@Model.Content.PrimaryActionText</a>
                <a class="button button--ghost" href="@RouteService.GetPath(Model.Culture, "services")">@Model.Content.SecondaryActionText</a>
            </div>
            <div class="metrics-grid">
                @foreach (var metric in Model.Content.Metrics)
                {
                    <article class="metric-card">
                        <strong>@metric.Value</strong>
                        <span>@metric.Label</span>
                    </article>
                }
            </div>
        </div>
        <aside class="hero-panel">
            <div class="hero-panel__inner">
                <p class="panel-kicker">Adoztech</p>
                <p class="panel-title">@Localizer["NextStepLabel"]</p>
                <p class="panel-copy">@Model.Content.CallToAction.Description</p>
                <ul class="panel-list">
                    @foreach (var item in panelItems)
                    {
                        <li>@item</li>
                    }
                </ul>
            </div>
        </aside>
    </div>
</section>

<section class="section-block">
    <div class="container">
        <div class="section-heading">
            <span class="eyebrow">@Localizer["ServicesOverviewLabel"]</span>
            <h2>@Model.Content.Services.Count @Localizer["NavServices"]</h2>
        </div>
        <div class="card-grid card-grid--services">
            @foreach (var service in Model.Content.Services)
            {
                <article class="content-card">
                    <h3>@service.Title</h3>
                    <p>@service.Description</p>
                </article>
            }
        </div>
    </div>
</section>

<section class="section-block section-block--tinted">
    <div class="container">
        <div class="section-heading">
            <span class="eyebrow">@Localizer["WhyAdoztechLabel"]</span>
            <h2>@Model.Content.ContactSummary.Title</h2>
        </div>
        <div class="card-grid">
            @foreach (var reason in Model.Content.Reasons)
            {
                <article class="content-card">
                    <h3>@reason.Title</h3>
                    <p>@reason.Description</p>
                </article>
            }
        </div>
    </div>
</section>

<section class="section-block">
    <div class="container">
        <div class="section-heading">
            <span class="eyebrow">@Localizer["ProcessOverviewLabel"]</span>
            <h2>@Model.Content.CallToAction.Title</h2>
        </div>
        <div class="steps-grid">
            @foreach (var step in Model.Content.ProcessSteps)
            {
                <article class="step-card">
                    <span class="step-index">@step.Step</span>
                    <h3>@step.Title</h3>
                    <p>@step.Description</p>
                </article>
            }
        </div>
    </div>
</section>

<section class="section-block section-block--tinted">
    <div class="container">
        <div class="section-heading">
            <span class="eyebrow">@Localizer["FeaturedProjectsLabel"]</span>
            <h2>@Model.Content.FeaturedProjects.Count @Localizer["NavProjects"]</h2>
        </div>
        <div class="card-grid card-grid--projects">
            @foreach (var project in Model.Content.FeaturedProjects)
            {
                <article class="project-card">
                    <img src="@project.ImagePath" alt="@project.ImageAlt" />
                    <div class="project-card__body">
                        <span class="badge">@project.Category</span>
                        <h3>@project.Title</h3>
                        <p>@project.Summary</p>
                        <p class="project-tech">@project.TechnologyStack</p>
                        <a class="button button--ghost button--sm" href="@RouteService.GetPath(Model.Culture, "projectDetail", project.Slug)">@Localizer["ProjectDetailsLabel"]</a>
                    </div>
                </article>
            }
        </div>
    </div>
</section>

<section class="section-block">
    <div class="container cta-panel">
        <div>
            <span class="eyebrow">@Localizer["ContactSummaryLabel"]</span>
            <h2>@Model.Content.ContactSummary.Title</h2>
            <p>@Model.Content.ContactSummary.Description</p>
        </div>
        <div class="hero-actions">
            <a class="button button--primary" href="@RouteService.GetPath(Model.Culture, "contact")">@Model.Content.ContactSummary.PrimaryActionText</a>
            <a class="button button--ghost" href="@RouteService.GetPath(Model.Culture, "process")">@Model.Content.ContactSummary.SecondaryActionText</a>
        </div>
    </div>
</section>
