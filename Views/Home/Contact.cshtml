@model ContactPageViewModel
@{
    ViewData["Seo"] = Model.Seo;
}
<section class="page-hero">
    <div class="container page-grid">
        <div>
            <span class="eyebrow">@Model.Content.Eyebrow</span>
            <h1>@Model.Content.Title</h1>
            <p class="lead">@Model.Content.Lead</p>
            <div class="contact-list">
                @foreach (var detail in Model.Content.Details)
                {
                    <article class="detail-card">
                        <span>@detail.Label</span>
                        <a href="@detail.Url">@detail.Value</a>
                    </article>
                }
            </div>
        </div>
        <div>
            <div class="section-heading section-heading--compact">
                <h2>@Model.Content.FormTitle</h2>
                <p>@Model.Content.FormLead</p>
            </div>
            @await Html.PartialAsync("_ContactForm", Model.Form)
        </div>
    </div>
</section>
