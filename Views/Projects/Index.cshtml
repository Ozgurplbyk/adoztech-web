@using Adoztech.Web.Resources
@using Adoztech.Web.Services.Routing
@inject IStringLocalizer<SharedResource> Localizer
@inject ICultureRouteService RouteService
@model PortfolioPageViewModel
@{
    ViewData["Seo"] = Model.Seo;
}
<section class="page-hero">
    <div class="container narrow">
        <span class="eyebrow">@Model.Content.Eyebrow</span>
        <h1>@Model.Content.Title</h1>
        <p class="lead">@Model.Content.Lead</p>
    </div>
</section>
<section class="section-block">
    <div class="container card-grid card-grid--projects">
        @foreach (var project in Model.Content.Projects)
        {
            <article class="project-card">
                <img src="@project.ImagePath" alt="@project.ImageAlt" />
                <div class="project-card__body">
                    <span class="badge">@project.Category</span>
                    <h2>@project.Title</h2>
                    <p>@project.Summary</p>
                    <p class="project-tech">@project.TechnologyStack</p>
                    <p class="project-outcome">@project.Outcome</p>
                    <a class="button button--ghost button--sm" href="@RouteService.GetPath(Model.Culture, "projectDetail", project.Slug)">@Localizer["ProjectDetailsLabel"]</a>
                </div>
            </article>
        }
    </div>
</section>
