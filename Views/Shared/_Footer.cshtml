@using Adoztech.Web.Options
@using Adoztech.Web.Resources
@using Adoztech.Web.Services.Routing
@using Microsoft.Extensions.Options
@inject IOptions<SiteSettings> SiteOptions
@inject IOptions<BrandingSettings> BrandingOptions
@inject IStringLocalizer<SharedResource> Localizer
@inject ICultureRouteService RouteService
@{
    var currentCulture = (ViewContext.RouteData.Values["culture"]?.ToString() ?? "tr").ToLowerInvariant();
    var site = SiteOptions.Value;
    var brand = BrandingOptions.Value;
    var brandTagline = currentCulture == "tr" ? brand.TaglineTr : brand.TaglineEn;
}
<footer class="site-footer">
    <div class="container footer-grid">
        <div>
            <a class="brand-mark brand-mark--footer" href="@RouteService.GetPath(currentCulture, "home")">
                <span class="brand-mark__badge">A</span>
                <span class="brand-mark__text">@brand.LogoText</span>
            </a>
            <p class="footer-copy">@brandTagline</p>
        </div>
        <div>
            <h2>@Localizer["FooterLegal"]</h2>
            <ul class="footer-links">
                <li><a href="@RouteService.GetPath(currentCulture, "privacy")">@Localizer["PrivacyPolicyLabel"]</a></li>
                <li><a href="@RouteService.GetPath(currentCulture, "kvkk")">@Localizer["KvkkLabel"]</a></li>
            </ul>
        </div>
        <div>
            <h2>@Localizer["FooterFollowUs"]</h2>
            <ul class="footer-links">
                <li><a href="@site.LinkedinUrl" target="_blank" rel="noopener">LinkedIn</a></li>
                <li><a href="@site.InstagramUrl" target="_blank" rel="noopener">Instagram</a></li>
                <li><a href="mailto:@site.ContactEmail">@site.ContactEmail</a></li>
            </ul>
        </div>
    </div>
    <div class="container footer-bar">
        <p>@site.SiteName © @DateTime.UtcNow.Year. @Localizer["FooterRights"]</p>
    </div>
</footer>
