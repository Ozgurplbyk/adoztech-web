@using Adoztech.Web.Resources
@inject IStringLocalizer<SharedResource> Localizer
@model ContactFormViewModel
<form method="post" class="form-card">
    @Html.AntiForgeryToken()
    <p class="form-note">@Localizer["FormNoticeLabel"]</p>
    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>
    <div class="form-grid">
        <div class="field">
            <label asp-for="FullName">@Localizer["ContactFullNameLabel"]</label>
            <input asp-for="FullName" autocomplete="name" />
            <span asp-validation-for="FullName"></span>
        </div>
        <div class="field">
            <label asp-for="Email">@Localizer["EmailAddressLabel"]</label>
            <input asp-for="Email" autocomplete="email" />
            <span asp-validation-for="Email"></span>
        </div>
        <div class="field">
            <label asp-for="Phone">@Localizer["PhoneLabel"]</label>
            <input asp-for="Phone" autocomplete="tel" />
            <span asp-validation-for="Phone"></span>
        </div>
        <div class="field">
            <label asp-for="Subject">@Localizer["SubjectLabel"]</label>
            <input asp-for="Subject" />
            <span asp-validation-for="Subject"></span>
        </div>
        <div class="field field--full">
            <label asp-for="Message">@Localizer["MessageLabel"]</label>
            <textarea asp-for="Message" rows="6"></textarea>
            <span asp-validation-for="Message"></span>
        </div>
    </div>
    <button class="button button--primary" type="submit">@Localizer["SubmitContactLabel"]</button>
</form>
